# Server Configuration
PORT=8001
# DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require
NODE_ENV=development

# Database Configuration
DB_STORAGE=./database.sqlite

# Auth Configuration
JWT_SECRET=your_jwt_secret_here
# Obligatorio en producción: debe ser DISTINTO de JWT_SECRET.
REFRESH_TOKEN_SECRET=your_separate_refresh_secret_here
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=10

# URLs
FRONTEND_URL=http://localhost:5000

# Observabilidad (opcional)
# LOG_LEVEL: debug | info | warn | error (default: debug en dev, info en prod)
# LOG_LEVEL=info
# Reporte de errores externo (requiere: npm install @sentry/node)
# SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/XXXX
# SENTRY_TRACES_SAMPLE_RATE=0

# Seeding Data (Optional)
SEED_ADMIN_NAME=Administrador
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin_password
SEED_TECH_NAME=Técnico Hidrobombas
SEED_TECH_EMAIL=tech@example.com
SEED_TECH_PASSWORD=tech_password

# ── Email ─────────────────────────────────────────────────────────────────────
# El servicio elige proveedor segun la key presente: Brevo > Resend > simulado.
# Sin ninguna key, los correos se SIMULAN (no se envian) — util en tests/CI.
#
# Opcion gratis SIN dominio propio (recomendada): Brevo.
#   1. Crea cuenta en https://www.brevo.com (300 emails/dia gratis).
#   2. Verifica un remitente (tu correo) en Senders & IP > Senders.
#   3. Genera una API key en SMTP & API > API Keys.
BREVO_API_KEY=xkeysib_your_brevo_api_key
BREVO_SENDER_EMAIL=tu_correo_verificado@gmail.com
BREVO_SENDER_NAME=CMMS Hidrobombas Mérida

# Alternativa: Resend (requiere verificar un dominio para enviar a terceros).
# RESEND_API_KEY=re_your_resend_api_key
# RESEND_FROM_EMAIL=CMMS Hidrobombas <reportes@tudominio.com>

# En desarrollo: redirige TODOS los correos a esta direccion (no envia a clientes).
# EMAIL_DEV_OVERRIDE_TO=tu_correo@gmail.com

# ── AI / LangChain ────────────────────────────────────────────────────────────
# Groq API (gratis: https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_api_key
# Modelo de Groq para el Agent Maestro (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Máximo de peticiones a /api/ai por ventana de 15 min (default: 30)
AI_RATE_LIMIT_MAX=30

# HuggingFace Inference API (gratis: https://huggingface.co/settings/tokens)
HUGGINGFACEHUB_API_KEY=hf_your_huggingface_token

# Vector Store Provider (memory | pgvector)
# "memory"  → MemoryVectorStore (en RAM, se pierde al reiniciar, ideal para desarrollo)
# "pgvector" → PostgreSQL con extensión pgvector (requiere DATABASE_URL y la
#              extensión 'vector' instalada: CREATE EXTENSION IF NOT EXISTS vector)
VECTOR_STORE_PROVIDER=memory
# Tabla donde pgvector persiste los embeddings (default: ai_report_embeddings)
# PGVECTOR_TABLE=ai_report_embeddings
