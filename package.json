{
  "name": "cmms-hidrobombas-merida",
  "version": "1.0.0",
  "description": "CMMS Monorepo Root",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "node -e \"if (process.env.CI || process.env.VERCEL) { console.log('Husky skipped in CI/Vercel'); process.exit(0); } require('child_process').execSync('husky', { stdio: 'inherit' });\"",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm start",
    "start": "npm run dev",
    "test": "concurrently \"npm run test:backend\" \"npm run test:frontend\"",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm run test:run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "load:smoke": "k6 run k6/scenarios/smoke.js",
    "load:test": "k6 run k6/scenarios/load.js",
    "load:stress": "k6 run k6/scenarios/stress.js",
    "load:write": "k6 run k6/scenarios/write-flow.js",
    "load:rate-limit": "k6 run k6/scenarios/rate-limit.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^8.2.2",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^17.0.4",
    "playwright": "^1.60.0",
    "supertest": "^7.2.2"
  },
  "lint-staged": {
    "frontend/src/**/*.{js,jsx}": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8"
  }
}
